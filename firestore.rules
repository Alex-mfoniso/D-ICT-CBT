rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // CBT app data: exam bank, student accounts, and scores.
    match /cbtExams/{docId} {
      allow read, write: if true;
    }

    match /cbtScores/{docId} {
      allow read, write: if true;
    }
  }
}
